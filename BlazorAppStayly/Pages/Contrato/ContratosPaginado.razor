@page "/contratos"
@using System.Net.Http.Json
@using System.Text.Json
@inject NavigationManager NavigationManager
@inject IHttpClientFactory ClientFactory
@using Model.DTO
@using MudBlazor
@using Blazored.LocalStorage
@using System.Net.Http.Headers
@using System.Text
@using System.Net
@using System.Reflection.Metadata
@inject ILocalStorageService localStorage
@inject IDialogService DialogService
@inject UserStateService UserStateService



<PageTitle>Contratos</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Class="pa-5" Elevation="3">
            <MudItem Class="d-flex align-content-start justify-content-start mud-width-full" xs="12">
                <MudItem Class="d-flex align-content-start justify-start mud-width-full" xs="6">
                    <MudText Typo="Typo.h6" Color="Color.Primary">Contratos</MudText>
                </MudItem>
            </MudItem>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-5" Elevation="3">
            <MudTable Items="@contratosFiltrados" RowsPerPage="@registroPagina" SortLabel="Sort By" FixedHeader="true" Dense="true"
            Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Loading="@cargando"
            LoadingProgressColor="Color.Primary" Height="466px" Elevation="3">
                <ToolBarContent>
                    <MudItem Class="d-flex flex-column flex-sm-row align-start align-sm-center justify-between mud-width-full py-2" xs="12">

                        <MudItem xs="12" sm="8" Class="d-flex align-center mud-width-full mb-2 mb-sm-0">
                            <MudTextField T="string" Value="@searchTerm" ValueChanged="@(value => OnSearch(value))"
                                          Placeholder="Buscar por N° de documento" Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                                          Class="mt-0" Style="margin-top: 0 !important;">
                            </MudTextField>
                        </MudItem>

                        <MudItem xs="12" sm="4" Class="d-flex align-center justify-start justify-sm-end">
                            <MudChipSet T="string" @bind-SelectedValue="filtroEstado" SelectionMode="SelectionMode.SingleSelection">
                                <MudChip Value="@("todos")" Color="Color.Default" Variant="Variant.Filled"
                                         Size="Size.Small" Default="true">Todos</MudChip>
                                <MudChip Value="@("cerrados")" Color="Color.Error" Variant="Variant.Filled"
                                         Size="Size.Small">Cerrados</MudChip>
                                <MudChip Value="@("activos")" Color="Color.Success" Variant="Variant.Filled"
                                         Size="Size.Small">Activos</MudChip>
                            </MudChipSet>
                        </MudItem>

                    </MudItem>
                </ToolBarContent>
                <HeaderContent>

                    <MudTh> <MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.ContratoCodigo)"> Codigo</MudTableSortLabel></MudTh>
                    <MudTh Style="max-width: 150px;">
                        <MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.DescripcionContrato)">
                            Descripción
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.FechaInicio)"> Fecha Inicio</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.FechaFin)"> Fecha Fin</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.PrecioAlquiler)"> Alquiler</MudTableSortLabel></MudTh>
                    <MudTh Style="max-width: 150px;"><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.NombreUsuario)"> Usuario</MudTableSortLabel></MudTh>
                    <MudTh Style="max-width: 150px;"><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.NombreCliente)"> Inquilino</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.NumDocumento)"> DNI Inquilino</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.AlojamientoCodigo)"> Habitación</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.AdelantoC)"> Adelanto</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DTO_Contrato_Obten_Paginado, object>(x => x.GarantiaC)"> Garantía</MudTableSortLabel></MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>

                    <MudTd DataLabel="Codigo">@context.ContratoCodigo</MudTd>
                    <MudTd DataLabel="Descripcion" Style="max-width: 150px;">
                        <MudTooltip Text="@context.DescripcionContrato" Placement="Placement.Top">
                            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                @context.DescripcionContrato
                            </div>
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Fecha Inicio">@context.FechaInicio</MudTd>
                    <MudTd DataLabel="Fecha Fin">@context.FechaFin</MudTd>
                    <MudTd DataLabel="Alquiler">@context.PrecioAlquiler</MudTd>
                    <MudTd DataLabel="Usuario" Style="max-width: 150px;">
                        <MudTooltip Text="@context.NombreUsuario" Placement="Placement.Top">
                            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                @context.NombreUsuario
                            </div>
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Inquilino" Style="max-width: 150px;">
                        <MudTooltip Text="@context.NombreCliente" Placement="Placement.Top">
                            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                @context.NombreCliente
                            </div>
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="DNI Inquilino">@context.NumDocumento</MudTd>
                    <MudTd DataLabel="Habitación">@context.AlojamientoCodigo</MudTd>
                    <MudTd DataLabel="Adelanto">@context.AdelantoC</MudTd>
                    <MudTd DataLabel="Garantía">@context.GarantiaC</MudTd>
                    <MudTd DataLabel="Acciones">
                        <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                                       @onclick="@(() => Btn_Mostrar_Pagos_Click(context.IdContrato))"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary">
                        </MudIconButton>
                        @if (@context.EstadoContrato == true)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           @onclick="@(() => Btn_Cerrar_Contrato_Click(_maxWidth, context.IdContrato))"
                                           Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Title="Eliminar contrato">
                            </MudIconButton>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="d-flex flex-column align-center">
                        <MudPagination Size="Size.Small" Rectangular="true" Variant="Variant.Text" BoundaryCount="1"
                                       MiddleCount="3" Count="@metaData.TotalPagina" SelectedChanged="PageChanged" Class="pa-4" />
                    </div>
                </PagerContent>
                <NoRecordsContent>
                    <MudText>No se encontraron registros.</MudText>
                </NoRecordsContent>
                <LoadingContent>
                    <MudText>Un momento por favor...</MudText>
                </LoadingContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<DTO_Contrato_Obten_Paginado> contratos;
    private MetaData metaData = new MetaData();
    private int registroPagina = 10;
    private int numeroPagina = 1;
    private string searchTerm = string.Empty;
    private bool cargando = true;
    private string errorMessage = string.Empty;
    private readonly DialogOptions _maxWidth = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private string filtroEstado = "todos";

    // 2. Propiedad computada que filtra localmente
    private IEnumerable<DTO_Contrato_Obten_Paginado> contratosFiltrados =>
        filtroEstado switch
        {
            "cerrados" => contratos?.Where(p => p.EstadoContrato == false) ?? Enumerable.Empty<DTO_Contrato_Obten_Paginado>(),
            "activos" => contratos?.Where(p => p.EstadoContrato == true) ?? Enumerable.Empty<DTO_Contrato_Obten_Paginado>(),
            _ => contratos ?? Enumerable.Empty<DTO_Contrato_Obten_Paginado>()
        };


    protected override async Task OnInitializedAsync()
    {
        var token = await localStorage.GetItemAsync<string>("authToken");
        if (string.IsNullOrEmpty(token))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        await LoadClients();
    }

    private async Task LoadClients()
    {
        try
        {
            cargando = true;
            var client = ClientFactory.CreateClient("ApiStayly");

            // Agregar el token de autorización a la solicitud actual
            var token = await localStorage.GetItemAsync<string>("authToken");
            if (token != null)
            {
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            var requestUri = $"api/Contrato/Obten_Paginado/{registroPagina}/{numeroPagina}";

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                requestUri += $"?TerBusqueda={Uri.EscapeDataString(searchTerm)}";
            }

            var response = await client.GetAsync(requestUri);

            if (response.IsSuccessStatusCode)
            {
                var metadataHeader = response.Headers.GetValues("X-Pagination").FirstOrDefault();
                if (metadataHeader != null)
                {
                    metaData = JsonSerializer.Deserialize<MetaData>(metadataHeader);
                }

                var responseBody = await response.Content.ReadFromJsonAsync<DTO_ResponsePag<IEnumerable<DTO_Contrato_Obten_Paginado>>>();
                if (responseBody != null && responseBody.IsSuccessful)
                {
                    contratos = responseBody.Data;
                }
            }
            else
            {
                Console.WriteLine($"Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void PageChanged(int page)
    {
        numeroPagina = page;
        _ = LoadClients();
    }

    private void OnSearch(string searchTerm)
    {
        this.searchTerm = searchTerm;
        numeroPagina = 1; // Reset to first page when searching
        _ = LoadClients();
    }
    private Task Btn_Cerrar_Contrato_Click(DialogOptions options, string IdContrato)
    {

        var parameters = new DialogParameters
        {
            { "IdContrato", IdContrato}
        };
        return DialogService.ShowAsync<CerrarContratoDialog>("Cerrar Contrato", parameters, options);
    }
    private Task Btn_Mostrar_Pagos_Click(string IdContrato)
    {
        NavigationManager.NavigateTo($"/pagos/{IdContrato}");
        return Task.CompletedTask;
    }
}
