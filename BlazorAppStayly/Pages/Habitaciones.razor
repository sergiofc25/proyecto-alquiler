@page "/habitaciones"
@using Model.DTO
@using MudBlazor
@inject IHttpClientFactory ClientFactory
@using Blazored.LocalStorage
@inject ILocalStorageService localStorage
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@using Newtonsoft.Json

<PageTitle>Habitaciones</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var habitacion in Alojamiento)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard>

@*                     <MudCardMedia Image="@GetImagen(habitacion)" Height="200px" />
 *@
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@habitacion.CodigoAlojamiento</MudText>

                        <MudText Typo="Typo.body2">
                            @habitacion.Descripcion
                        </MudText>

                        <MudText Color="Color.Primary" Class="mt-2">
                            S/ @habitacion.Precio
                        </MudText>
                    </MudCardContent>

                    @* <MudCardActions>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true">
                            Alquilar
                        </MudButton>
                    </MudCardActions> *@
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(!habitacion.EstadoAlojamiento)">
                            @(habitacion.EstadoAlojamiento ? "Alquilar" : "No Disponible")
                        </MudButton>
                    </MudCardActions>

                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {

    private List<DTO_Alojamiento_Obten> Alojamiento = new();
    private string errorMessage = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await GetAlojamientos();
    }

    private async Task GetAlojamientos()
    {
        try
        {
            var client = ClientFactory.CreateClient("ApiStayly");

            var response = await client.GetAsync("api/Alojamiento/Alojamiento_Obten");

            if (response.IsSuccessStatusCode)
            {
                string responseBody = await response.Content.ReadAsStringAsync();

                //var result = JsonConvert.DeserializeObject<DTO_Response<List<DTO_Alojamiento_Obten>>>(responseBody);
                Alojamiento = JsonConvert.DeserializeObject<List<DTO_Alojamiento_Obten>>(responseBody) ?? new();

                if (response.IsSuccessStatusCode)
                {
                    Alojamiento = JsonConvert.DeserializeObject<List<DTO_Alojamiento_Obten>>(responseBody) ?? new();
                }
                else
                {
                    errorMessage = $"Error HTTP: {response.StatusCode}";
                }
            }
            else
            {
                errorMessage = $"Error HTTP: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // private string GetImagen(DTO_Alojamiento_Obten habitacion)
    // {
    //     return string.IsNullOrEmpty(habitacion.RutaAlojamiento)
    //         ? "imagenes/habitaciones/default.jpg"
    //         : habitacion.RutaAlojamiento;
    // }
}