@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#6200ea",
            Background = "#f4f4f8",
            Surface = "#ffffff",
            TextPrimary = "#212121",
            TextSecondary = "#616161",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#bb86fc",
            Background = "#121212",
            Surface = "#1e1e2e",
            TextPrimary = "#ffffff",
            TextSecondary = "#ffffffb3",
        }
    };
}