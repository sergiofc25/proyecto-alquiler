@using Newtonsoft.Json
@using System.Net.Http.Json
@using System.Text.Json
@inject NavigationManager NavigationManager
@inject IHttpClientFactory ClientFactory
@using Model.DTO
@using MudBlazor
@using Blazored.LocalStorage
@using System.Net.Http.Headers
@using System.Text
@using System.Net
@using System.Reflection.Metadata
@using System.Net.Http.Headers
@inject ILocalStorageService localStorage
@inject IDialogService DialogService
@inject UserStateService UserStateService


<MudDialog>
    <TitleContent>
        Alquilar Habitación
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="17">
                <MudPaper Class="pa-4">
                    <MudForm @ref="form" Validation="@formValidation">
                        <MudTextField @bind-Value="usuario.NombreUsuario"
                                        Label="Usuario"
                                        Required="true"
                                        ReadOnly="true"/>
                        <MudTextField @bind-Value="Alojamiento.CodigoAlojamiento"
                                      Label="Habitación"
                                      Required="true"
                                      ReadOnly="true" />
                        <MudTextField @bind-Value="Alojamiento.Descripcion"
                                      Label="Descripción"
                                      Required="true"
                                      ReadOnly="true" />
                        <MudTextField @bind-Value="Alojamiento.Precio"
                                      Label="Precio"
                                      Required="true"
                                      ReadOnly="true" />
                        <MudTextField @bind-Value="Alojamiento.Garantia"
                                      Label="Garantía"
                                      Required="true"
                                      ReadOnly="true" />
                        <MudAutocomplete T="DTO_Cliente_Obten_x_NumDocumento"
                                         Label="Número Documento"
                                         Text="@dni"
                                         TextChanged="OnDniChanged"
                                         Value="@cliente"
                                         ValueChanged="OnClienteSelected"
                                         SearchFunc="BuscarClientesApi"
                                         ToStringFunc="@(c => c?.NumDocumento)"
                                         MinCharacters="8"
                                         DebounceInterval="300"
                                         CoerceText="false"
                                         Required="true"
                                         ResetValueOnEmptyText="false"
                                         AdornmentIcon="@Icons.Material.Filled.Search" />
                        <MudTextField T="string" Required="true" Label="Nombre" @bind-Value="cliente.NombreCliente" />

                        <MudTextField T="string" Required="true" Label="Teléfono" @bind-Value="cliente.Telefono" />

                        <MudTextField T="string" Required="true" Label="Email" @bind-Value="cliente.Email" />
                        <MudSelect T="string" Required="true"
                                   Label="Tipo de Documento"
                                   @bind-Value="cliente.TipoDocumento">
                            @if (tipo_Documentos != null)
                            {
                                @foreach (var tipo in tipo_Documentos)
                                {
                                    <MudSelectItem T="string" Value="@tipo.TipoDocumeno">
                                        @tipo.TipoDocumeno
                                    </MudSelectItem>
                                }
                            }
                        </MudSelect>
                        <MudDatePicker Label="Fecha Inicio"
                                       @bind-Date="fechaInicio"
                                       Required="true"
                                       RequiredError="Fecha Requerida!" />

                        <MudDatePicker Label="Fecha Fin"
                                       @bind-Date="fechaFin" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.CleaningServices"
                                   OnClick="LimpiarCampos"
                                   Class="mt-4">
                            Limpiar Formulario
                        </MudButton>
                    </MudForm>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Guardar">Alquilar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
    private MudForm? form;
    private bool formValidation = true;
    private List<DTO_Tipo_Documento_Obten> tipo_Documentos = new();
    private string errorMessage = string.Empty;
    private DTO_Usuario_Obten_x_Correo usuario = new DTO_Usuario_Obten_x_Correo();
    private DTO_Cliente_Obten_x_NumDocumento cliente = new ();
    private DTO_Tipo_Documento_Obten selectedTipoDocumento { get; set; } = new DTO_Tipo_Documento_Obten();
    private DTO_Contrato_Crea nuevoContrato = new DTO_Contrato_Crea();
    private bool guardando = false;
    private string dni = "";
    private DateTime? fechaInicio;
    private DateTime? fechaFin;
    [Parameter]public DTO_Alojamiento_Obten Alojamiento { get; set; }


    protected override async Task OnInitializedAsync()
    {
        var token = await localStorage.GetItemAsync<string>("authToken");
        if (string.IsNullOrEmpty(token))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        await GetTipoDocumentos();
        await GetUsuario();
    }
    private void OnDniChanged(string text)
    {
        dni = text;

        if (cliente == null)
            cliente = new DTO_Cliente_Obten_x_NumDocumento();

        cliente.NumDocumento = text;
    }
    private void LimpiarCampos()
    {
        cliente = new DTO_Cliente_Obten_x_NumDocumento();
        dni = "";
    }
    private void OnClienteSelected(DTO_Cliente_Obten_x_NumDocumento seleccionado)
    {
        if (seleccionado != null)
        {
            cliente = seleccionado;
            dni = seleccionado.NumDocumento;
        }
    }
    
    private async Task<IEnumerable<DTO_Cliente_Obten_x_NumDocumento>> BuscarClientesApi(string value, CancellationToken cantoken)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(value))
                return Enumerable.Empty<DTO_Cliente_Obten_x_NumDocumento>();

            var client = ClientFactory.CreateClient("ApiStayly");

            var token = await localStorage.GetItemAsync<string>("authToken");

            if (token != null)
            {
                client.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await client.GetAsync($"api/Cliente/Obten_x_NumDocumento/{value}", cantoken);

            if (response.IsSuccessStatusCode)
            {
                var responseBody = await response.Content.ReadAsStringAsync(cantoken);

                var result = JsonConvert.DeserializeObject<
                    DTO_Response<DTO_Cliente_Obten_x_NumDocumento>
                >(responseBody);

                if (result != null && result.IsSuccessful && result.Data != null)
                {
                    return new List<DTO_Cliente_Obten_x_NumDocumento> { result.Data };
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

        return Enumerable.Empty<DTO_Cliente_Obten_x_NumDocumento>();
    }
    private async Task GetUsuario()
    {
        try
        {
            var client = ClientFactory.CreateClient("ApiStayly");
            var token = await localStorage.GetItemAsync<string>("authToken");
            if (!string.IsNullOrEmpty(token))
            {
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await client.GetAsync("api/Usuario/Obten_Usuario_Logeado");
            if (response.IsSuccessStatusCode)
            {
                string responseBody = await response.Content.ReadAsStringAsync();
                var result = JsonConvert.DeserializeObject<DTO_Response<DTO_Usuario_Obten_x_Correo>>(responseBody);

                if (result != null && result.IsSuccessful)
                {
                    usuario = result.Data;
                    UserStateService.SetUser(usuario);
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar usuario: {ex.Message}";
        }
        StateHasChanged();
    }
    private async Task GetTipoDocumentos()
    {
        try
        {
            var client = ClientFactory.CreateClient("ApiStayly");
            var token = await localStorage.GetItemAsync<string>("authToken");
            if (token != null)
            {
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await client.GetAsync("api/Tipo_Documento/Obten");
            Console.WriteLine($"Response Status: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                string responseBody = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Response Body: {responseBody}");
                var result = JsonConvert.DeserializeObject<DTO_Response<List<DTO_Tipo_Documento_Obten>>>(responseBody);
                if (result != null && result.IsSuccessful)
                {
                    tipo_Documentos = result.Data;
                    Console.WriteLine($"Documento Count: {tipo_Documentos.Count}");
                }
                else
                {
                    Console.WriteLine("Response not successful or no data.");
                }
            }
            else
            {
                Console.WriteLine($"Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar tipos de documento: {ex.Message}";
            Console.WriteLine(ex.Message);
        }
    }

    private async Task Guardar()
    {
        guardando = true;

        await form.Validate();

        if (!form.IsValid)
        {
            guardando = false;
            return;
        }

        try
        {
            var client = ClientFactory.CreateClient("ApiStayly");
            var token = await localStorage.GetItemAsync<string>("authToken");

            if (!string.IsNullOrEmpty(token))
            {
                client.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);
            }
            if (fechaInicio.HasValue)
                nuevoContrato.FechaInicio = DateOnly.FromDateTime(fechaInicio.Value);

            if (fechaFin.HasValue)
                nuevoContrato.FechaFin = DateOnly.FromDateTime(fechaFin.Value);


            nuevoContrato.NumDocumento = cliente.NumDocumento;
            nuevoContrato.NombreCliente = cliente.NombreCliente;
            nuevoContrato.TelefonoCliente = cliente.Telefono;
            nuevoContrato.EmailCliente = cliente.Email;
            nuevoContrato.TipoDocumento = cliente.TipoDocumento;
            nuevoContrato.NombreUsuario = usuario.NombreUsuario;
            nuevoContrato.AlojamientoCodigo = Alojamiento.CodigoAlojamiento;

            var response = await client.PostAsJsonAsync("api/Contrato/Crea", nuevoContrato);

            if (response.IsSuccessStatusCode)
            {
                Submit();
                NavigationManager.NavigateTo(NavigationManager.Uri, true);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine(errorContent);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al crear contrato: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }


}
