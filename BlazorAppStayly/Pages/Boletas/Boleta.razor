@page "/boleta/{IdPago}"
@using Model.DTO
@using MudBlazor
@inject IHttpClientFactory ClientFactory
@using Blazored.LocalStorage
@inject ILocalStorageService localStorage
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@using Newtonsoft.Json
@using System.Net.Http.Headers
@inject IJSRuntime JS



<PageTitle>Boleta</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
}
else
{
    <div class="d-flex justify-center align-center" style="min-height: 80vh; padding: 2rem;">
        <MudPaper Elevation="0" Style="width: 100%; max-width: 440px; border: 0.5px solid var(--mud-palette-divider); border-radius: 12px; padding: 2rem;">

            @* --- Header --- *@
            <div class="d-flex align-center mb-6 pb-4" style="border-bottom: 0.5px solid var(--mud-palette-divider);">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="margin-right: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 500; line-height: 1.2;">Boleta de pago</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@boleta.Codigo</MudText>
                </div>
                <MudSpacer />
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Pagado</MudChip>
            </div>

            @* --- Fechas --- *@
            <MudGrid Spacing="2" Class="mb-4">
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-3" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Fecha inicio</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@boleta.fecha</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudPaper Elevation="0" Class="pa-3" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Fecha fin</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@boleta.fechaFin</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="pa-3" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Fecha de pago</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@boleta.fechaPagoRealizado</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* --- Detalles --- *@
            <MudDivider Class="mb-4" />
            <MudSimpleTable Dense="true" Hover="false" Style="background: transparent;">
                <tbody>
                    <tr>
                        <td style="color: var(--mud-palette-text-secondary); font-size: 13px;">Cliente</td>
                        <td style="text-align: right; font-weight: 500; font-size: 13px;">@boleta.NombreCliente</td>
                    </tr>
                    <tr>
                        <td style="color: var(--mud-palette-text-secondary); font-size: 13px;">N° Documento</td>
                        <td style="text-align: right; font-weight: 500; font-size: 13px;">@boleta.NumDocumento</td>
                    </tr>
                    <tr>
                        <td style="color: var(--mud-palette-text-secondary); font-size: 13px;">Descripción</td>
                        <td style="text-align: right; font-weight: 500; font-size: 13px;">@boleta.descripcion</td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            @* --- Total --- *@
            <MudPaper Elevation="0" Class="d-flex justify-space-between align-center pa-4 mt-4"
                      Style="border-radius: 8px;">
                <MudText Typo="Typo.subtitle2" Color="Color.Default">Total</MudText>
                <MudText Typo="Typo.h6" Color="Color.Default" Style="font-weight: 500;">@boleta.total</MudText>
            </MudPaper>
            @* Exportar a pdf *@
            <MudPaper Elevation="0" Class="d-flex justify-space-between align-center pa-4 mt-4"
                      Style="border-radius: 8px;">
                <MudButton Color="Color.Primary" OnClick="ExportPdf">
                    Exportar PDF
                </MudButton>
            </MudPaper>

        </MudPaper>
    </div>
}

@code {

    private DTO_Boleta_Obten_x_Pago boleta = new();
    private MudForm? form;
    private bool formValidation = true;
    private string errorMessage = string.Empty;
    private bool _loading = true;


    [Parameter] public string? IdPago { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await GetBoleta(IdPago);
    }
    private async Task GetBoleta(string IdPago)
    {
        try
        {
            var client = ClientFactory.CreateClient("ApiStayly");
            var token = await localStorage.GetItemAsync<string>("authToken");
            if (token != null)
            {
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await client.GetAsync($"api/Boleta/Obten_x_Pago/{IdPago}");
            Console.WriteLine($"Response Status: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                string responseBody = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Response Body: {responseBody}");
                var result = JsonConvert.DeserializeObject<DTO_Response<DTO_Boleta_Obten_x_Pago>>(responseBody);
                if (result != null && result.IsSuccessful)
                {
                    boleta = result.Data;
                }
                else
                {
                    Console.WriteLine("Response not successful or no data.");
                }
            }
            else
            {
                Console.WriteLine($"Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar tipos de documento: {ex.Message}";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
    private async Task ExportPdf()
    {
        await JS.InvokeVoidAsync("exportBoletaPdf", boleta);
    }

}